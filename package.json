{
  "name": "ai-shield",
  "version": "1.0.0",
  "description": "Zero-dependency CLI tool for unified AI security orchestration across multiple platforms",
  "main": "dist/index.js",
  "bin": {
    "ai-shield": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "security",
    "orchestration",
    "cli",
    "enterprise",
    "threat-detection",
    "compliance",
    "openai",
    "anthropic",
    "google-ai",
    "azure-ai"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "commander": "^11.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.39.4",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.62.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/index.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint"
    ],
    "extends": [
      "eslint:recommended",
      "@typescript-eslint/recommended"
    ],
    "rules": {
      "@typescript-eslint/no-unused-vars": "error",
      "@typescript-eslint/no-explicit-any": "warn",
      "no-console": "warn"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sulthonzh/ai-shield.git"
  },
  "homepage": "https://github.com/sulthonzh/ai-shield#readme",
  "bugs": {
    "url": "https://github.com/sulthonzh/ai-shield/issues"
  },
  "types": "dist/index.d.ts"
}
