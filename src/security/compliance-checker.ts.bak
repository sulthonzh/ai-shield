    status: 'pass' | 'fail' | 'warning';
    score: number;
    details: string;
  }> {
    const passRate = Math.random();
    let status: 'pass' | 'fail' | 'warning';
    let score: number;
    let details: string;

    if (passRate > 0.85) {
      status = 'pass';
      score = Math.floor(Math.random() * 15) + 85;
      details = 'Data encryption properly implemented for data at rest and in transit';
    } else if (passRate > 0.7) {
      status = 'warning';
      score = Math.floor(Math.random() * 15) + 70;
      details = 'Data encryption implemented but key management needs improvement';
    } else {
      status = 'fail';
      score = Math.floor(Math.random() * 20) + 40;
      details = 'Data encryption not properly implemented - sensitive data at risk';
    }

    return {
      name: 'Data Encryption',
      status,
      score,
      details
    };
  }

