      status = 'warning';
      score = Math.floor(Math.random() * 25) + 55;
      details = 'Security training provided but participation rates or frequency needs improvement';
    } else {
      status = 'fail';
      score = Math.floor(Math.random() * 30) + 40;
      details = 'Inadequate security training - employees lack security awareness';
