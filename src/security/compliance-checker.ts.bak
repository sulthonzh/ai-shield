    if (passRate > 0.75) {
      status = 'pass';
      score = Math.floor(Math.random() * 20) + 80;
      details = 'Comprehensive audit logging implemented with appropriate retention policies';
    } else if (passRate > 0.6) {
      status = 'warning';
      score = Math.floor(Math.random() * 20) + 60;
      details = 'Audit logging partially implemented - some events may not be captured';
    } else {
      status = 'fail';
      score = Math.floor(Math.random() * 25) + 45;
      details = 'Audit logging inadequate - cannot track security events effectively';
    }

    return {
      name: 'Audit Logging',
      status,
      score,
      details
